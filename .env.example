# E-Lib Environment Configuration

# Database Configuration
DB_CONNECTION=mongo
DB_HOST=localhost
DB_PORT=27017
DB_DATABASE=e_lib
DB_USERNAME=
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your_secret_key_here
JWT_EXPIRATION=3600

# Email Configuration (PHPMailer)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support@epictetuslibrary.org
MAIL_FROM_NAME="Epictetus Library"
SUPPORT_EMAIL=support@epictetuslibrary.org

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# API Configuration
API_BASE_URL=http://127.0.0.1:8081/

# CAS Authentication
CAS_SERVER_URL=https://your-cas-server.com/cas

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here

# MongoDB Connection Options
# Use either ${MONGO_PASSWORD} or <db_password> in the URI; set MONGO_PASSWORD below (special chars are URL-encoded automatically).
MONGO_URI=mongodb+srv://username:${MONGO_PASSWORD}@your-cluster.mongodb.net/?tls=true&appName=e-lib
MONGO_PASSWORD=your_password_here
# Leave empty for Atlas (uses OS certificate store). Only set if you need a custom CA file path:
# MONGO_TLS_CA_FILE=
# Optional: set to 1 only if you explicitly want MongoDB Stable API in the driver handshake
# MONGO_SERVER_API=1

# Ngrok Configuration (for development tunneling)
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
